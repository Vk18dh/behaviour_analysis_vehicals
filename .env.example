# ── Database ─────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///traffic.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/traffic_db

# ── Security ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
ADMIN_USER=admin
ADMIN_PASS=admin123
AES_SECRET_KEY=CHANGEME_32bytes_key!!__padding__

# ── API URL (used by Streamlit dashboard) ────────────────────────────
API_BASE_URL=http://127.0.0.1:8000

# ── Email Notifications ───────────────────────────────────────────────
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECEIVER=traffic_authority@example.com

# ── SMS (mock by default) ─────────────────────────────────────────────
SMS_PROVIDER_URL=https://api.smsprovider.com/send
SMS_API_KEY=your_sms_api_key
